{
  "regions": ["fra1"],
  "buildCommand": "pnpm build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": "/api/auth/[...all]"
    },
    {
      "source": "/api/pms-api/(.*)",
      "destination": "/api/pms-api/[...path]"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
